app:
  name: "baokaobao"
  host: "0.0.0.0"
  port: 8080
  mode: "debug"

database:
  host: "127.0.0.1"
  port: 3306
  username: "root"
  password: "password"
  name: "baokaobao"
  max_idle_conns: 10
  max_open_conns: 100
  conn_max_lifetime: 3600

jwt:
  secret: "your-jwt-secret-key-change-in-production"
  expire_hours: 720

wechat:
  appid: "wx_your_appid"
  secret: "your_app_secret"

oss:
  endpoint: "oss-cn-hangzhou.aliyuncs.com"
  access_key_id: "your_access_key"
  access_key_secret: "your_secret"
  bucket: "baokaobao"

log:
  level: "debug"
  path: "./logs"
  max_size: 100
  max_backups: 30
