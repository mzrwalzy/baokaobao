<view class="login-page">
  <view class="logo-section">
    <view class="logo">
      <text class="logo-icon">📚</text>
    </view>
    <text class="app-name">刷题宝</text>
    <text class="app-slogan">轻松刷题，高效学习</text>
  </view>

  <view class="login-section">
    <button class="btn-login" bindtap="handleWxLogin">
      <text class="wx-icon">🍎</text>
      <text>微信一键登录</text>
    </button>
    
    <view class="agreement">
      登录即表示同意
      <text class="link" bindtap="openAgreement" data-type="user">《用户协议》</text>
      和
      <text class="link" bindtap="openAgreement" data-type="privacy">《隐私政策》</text>
    </view>
  </view>
</view>
