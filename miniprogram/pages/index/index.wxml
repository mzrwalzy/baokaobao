<view class="index-page">
  <view class="header">
    <view class="search-bar" bindtap="goSearch">
      <text class="search-icon">🔍</text>
      <text class="search-placeholder">搜索题库...</text>
    </view>
    <view class="notice-btn" bindtap="goNotice">
      <text>🔔</text>
    </view>
  </view>

  <scroll-view scroll-y class="content" bindscrolltolower="loadMore">
    <view class="section">
      <view class="section-title">
        <text class="title">热门题库</text>
      </view>
      
      <view class="bank-list">
        <view 
          class="bank-card" 
          wx:for="{{banks}}" 
          wx:key="id"
          bindtap="goBankDetail"
          data-bank="{{item}}"
        >
          <view class="bank-info">
            <view class="bank-icon">📚</view>
            <view class="bank-text">
              <text class="bank-name">{{item.name}}</text>
              <text class="bank-meta">题目: {{item.question_count}}+  |  难度: {{item.difficulty >= 1 ? '⭐' : ''}}{{item.difficulty >= 2 ? '⭐' : ''}}{{item.difficulty >= 3 ? '⭐' : ''}}{{item.difficulty >= 4 ? '⭐' : ''}}{{item.difficulty >= 5 ? '⭐' : ''}}</text>
            </view>
          </view>
          <view class="bank-action">
            <text class="start-btn">开始刷题</text>
          </view>
        </view>
      </view>

      <view class="loading-tip" wx:if="{{loading}}">
        <text>加载中...</text>
      </view>
      <view class="no-more" wx:if="{{noMore && banks.length > 0}}">
        <text>没有更多了</text>
      </view>
    </view>
  </scroll-view>
</view>
